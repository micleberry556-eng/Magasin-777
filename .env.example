# ============================================
# LocalMarket - Конфигурация окружения
# ============================================
# Скопируйте этот файл в .env и измените значения:
#   cp .env.example .env

# --- Database (PostgreSQL) ---
DB_USER=admin
DB_PASSWORD=secret
DB_NAME=localmarket

# --- MinIO (Object Storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Evaluator Service ---
# Оставьте пустым для использования встроенного алгоритма оценки.
# Укажите URL внешнего сервиса для проксирования запросов.
EVALUATOR_EXTERNAL_URL=
