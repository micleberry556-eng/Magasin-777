# ============================================
# LocalMarket - Конфигурация окружения
# ============================================
# Скопируйте этот файл в .env и измените значения:
#   cp .env.example .env

# --- Database (PostgreSQL) ---
DB_USER=admin
DB_PASSWORD=secret
DB_NAME=localmarket

# --- MinIO (Object Storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Backend ---
SECRET_KEY=change-me-in-production-very-secret-key-2026

# --- Admin Panel ---
# Логин и пароль для первого администратора (создается при первом запуске)
ADMIN_EMAIL=admin@localmarket.com
ADMIN_PASSWORD=admin123
